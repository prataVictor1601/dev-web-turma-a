//Funções assícronas permitem executar operações sem bloquear a execução do código

async function buscarDados () {
return new Promise((resolve) => {

    setTimeout(() => {
        resolve("Dados Recebidos");
    }, 4 * 1000);
});

    
}

async function executarBusca () {
    log("Buscando.....");
    let resultado = buscarDados ();
    log(resultado);
    
}

executarBusca();

