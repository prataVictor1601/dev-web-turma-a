{"ast":null,"code":"export default {\n  name: \"PedidoComponent\",\n  props: {\n    burguer: null\n  },\n  data() {\n    return {\n      listaPontoCarne: [],\n      listaBebidas: [],\n      listaComplementos: [],\n      nomeCliente: \"\",\n      pontoCarnesSelecionado: \"\",\n      listaComplementosSelecionado: [],\n      listaBebidasSelecionadas: []\n    };\n  },\n  methods: {\n    async getTipoPontos() {\n      const response = await fetch(\"http://localhost:3000/tipos_pontos\");\n      const dados = await response.json();\n      this.listaPontoCarne = dados;\n    },\n    async getOpcionais() {\n      const response = await fetch(\"http://localhost:3000/opcionais\");\n      const dados = await response.json();\n      this.listaComplementos = dados.complemento;\n      this.listaBebidas = dados.bebidas;\n    },\n    async criarPedido(E) {\n      const dadosPedido = {\n        nome: \"\",\n        ponto: \"\",\n        bebidas: [],\n        complemento: [],\n        burguer: this.burguer,\n        statusId: 5\n      };\n    }\n  },\n  mounted() {\n    this.getTipoPontos();\n    this.getOpcionais();\n  }\n};","map":{"version":3,"names":["name","props","burguer","data","listaPontoCarne","listaBebidas","listaComplementos","nomeCliente","pontoCarnesSelecionado","listaComplementosSelecionado","listaBebidasSelecionadas","methods","getTipoPontos","response","fetch","dados","json","getOpcionais","complemento","bebidas","criarPedido","E","dadosPedido","nome","ponto","statusId","mounted"],"sources":["C:\\Users\\lucas.kauan\\Desktop\\GitHub\\dev-web-turma-a\\Lucas Kauan\\Projeto Final\\tburguer\\src\\components\\PedidoComponent.vue"],"sourcesContent":["<template>\r\n    <div>\r\n        <form id=\"pedido-form\">\r\n            <div>\r\n                <p id=\"nome-hamburguer-content\">\r\n                    {{ burguer && burguer.nome ? burguer.nome : \"-\" }}\r\n                </p>\r\n                <img id=\"foto-content\" :src=\"burguer && burguer.foto ? burguer.foto : ''\