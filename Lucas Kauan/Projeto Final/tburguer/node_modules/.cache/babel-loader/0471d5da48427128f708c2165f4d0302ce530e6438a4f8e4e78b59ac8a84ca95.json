        <div class=\"checkbox-container\">\r\n                    <input type=\"checkbox\" name=\"complemento\"/>\r\n                    <span>Refri</span>\r\n                </div>\r\n\r\n                <label>Adicione uma bebida</label>\r\n                \r\n                <div id=\"checkbox-container\">\r\n                    <input type=\"checkbox\" name=\"bebida\"/>\r\n                    <span>Coca</span>\r\n                </div>\r\n                <div class=\"inputs\">\r\n                    <input type=\"submit\" class=\"submit-btn\" value=\"Confirmar Pedido\">\r\n                </div>\r\n            </div>\r\n        </form>\r\n    </div>\r\n</template>\r\n<script>\r\nexport default {\r\n    name: \"PedidoComponent\",\r\n    props: {\r\n        burguer: null,        \r\n    },\r\n    data(){\r\n        return {\r\n            listaPontoCarne: [],\r\n        };\r\n    },\r\n    methods: {\r\n        async getTipoPontos() {\r\n            const response = fetch (\"http://localhost:3000/tipos_pontos\");\r\n            const dados = (await response).json();\r\n            this.listaPontoCarne = dados;\r\n        },\r\n    },\r\n    mounted() {\r\n        this.getTipoPontos();\r\n    }\r\n};\r\n</script>\r\n<style scoped></style>"],"mappings":"AAgDA,eAAe;EACXA,IAAI,EAAE,iBAAiB;EACvBC,KAAK,EAAE;IACHC,OAAO,EAAE;EACb,CAAC;EACDC,IAAIA,CAAA,EAAE;IACF,OAAO;MACHC,eAAe,EAAE;IACrB,CAAC;EACL,CAAC;EACDC,OAAO,EAAE;IACL,MAAMC,aAAaA,CAAA,EAAG;MAClB,MAAMC,QAAO,GAAIC,KAAI,CAAG,oCAAoC,CAAC;MAC7D,MAAMC,KAAI,GAAI,CAAC,MAAMF,QAAQ,EAAEG,IAAI,CAAC,CAAC;MACrC,IAAI,CAACN,eAAc,GAAIK,KAAK;IAChC;EACJ,CAAC;EACDE,OAAOA,CAAA,EAAG;IACN,IAAI,CAACL,aAAa,CAAC,CAAC;EACxB;AACJ,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}