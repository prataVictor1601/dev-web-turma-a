{"ast":null,"code":"export default {\n  name: \"PedidoComponent\",\n  props: {\n    burguer: null\n  },\n  data() {\n    return {\n      listaPontosCarne: [],\n      ListaBebidas: [],\n      ListaComplementos: []\n    };\n  },\n  methods: {\n    async getTipoPontos() {\n      const response = await fetch(\"http://localhost:3000/tipos_pontos\");\n      const dados = await response.json();\n      this.listaPontosCarne = dados;\n    },\n    async getOpcionas() {\n      const response = await fetch(\"http://localhost:3000/opcionais\");\n      const dados = await response.json();\n      this.ListaComplementos = dados;\n      this.ListaBebidas = dados;\n    }\n  },\n  mounted() {\n    this.getTipoPontos();\n    this.getOpcionas();\n  }\n};","map":{"version":3,"names":["name","props","burguer","data","listaPontosCarne","ListaBebidas","ListaComplementos","methods","getTipoPontos","response","fetch","dados","json","getOpcionas","mounted"],"sources":["C:\\Users\\muriloyukisukiyama21\\Desktop\\Git\\dev-web-turma-a\\Murilo Yuki\\Projeto Final\\tburguer\\src\\components\\PedidoComponent.vue"],"sourcesContent":["<template>\r\n    <div>\r\n        <form id=\"pedido-form\">\r\n            <div>\r\n                <p>\r\n                    {{ burguer && burguer.nome? burguer.nome: \"-\"}}\r\n                </p>\r\n                <img\r\n                id=\"foto-content\" \r\n                :src=\"burguer && burguer.foto? burguer.foto:''\">\r\n            </div>\r\n            <div class=\"inputs \" id = \"form-pedido\">\r\n                <label>Nome</label>\r\n                <input \r\n                type=\"text\" \r\n                id=\"nome-cliente\" \r\n                name=\"nome-cliente\" \r\n                placeholder=\"Digite seu nome\"\r\n                />\r\n            </div>\r\n            <div class=\"inputs \">\r\n                <label>Ponto da carne</label>\r\n                <select name=\"ponto-carne\" id=\"ponto-carne\">\r\n                    <option value=\"\">Selecione o ponto</option>\r\n                    <option \r\n                    v-for=\"pontoCarne in listaPontosCarne\" \r\n                    :key=\"pontoCarne.id\" \r\n                    >\r\n                    {{ pontoCarne.descricao }}\r\n                </option>\r\n                </select>\r\n            </div>\r\n            <div class=\"inputs\">\r\n                <label id=\"opcionais-titulo\">Selecione os opcionais</label>\r\n                <label id=\"opcionais-subtitulo\">Selecione os complementos</label>\r\n\r\n                <div class=\" checkbox-container\" \r\n                v-for=\"complemento in ListaComplementos\" \r\n                :key=\"complemento.id\">\r\n                    <input type=\"checkbox\" name=\"complemento.nome\" :value=\"complemento\">\r\n                    <span>{{ complemento.nome }}</span>\r\n                </div>\r\n\r\n                <label> Adicione uma bebida</label>\r\n\r\n                <div class=\" checkbox-container\" v-for=\"bebidas in ListaBebidas\" \r\n                :key=\"bebidas.id\">\r\n                    <input type=\"checkbox\" :name=\"bebidas.nome\" :value = \"bebidas\"\r\n                    >\r\n                    <span>{{ bebidas.nome }}</span>\r\n                </div>\r\n\r\n                <div class=\"inputs\">\r\n                    <input type=\"submit\" class=\"submit-btn\" value=\"Confirmar Pedido\">\r\n                </div>\r\n            </div>\r\n        </form>\r\n    </div>\r\n</template>\r\n<script>\r\n    export default{\r\n        name: \"PedidoComponent\",\r\n        props: {\r\n            burguer: null,\r\n        },\r\n        data() {\r\n            return {\r\n                listaPontosCarne: [],\r\n                ListaBebidas:[],\r\n                ListaComplementos:[]\r\n            };\r\n        },\r\n        methods: {\r\n            async getTipoPontos() {\r\n                const response = await fetch(\"http://localhost:3000/tipos_pontos\")\r\n                const dados = await response.json();\r\n                this.listaPontosCarne = dados;\r\n            },\r\n            async getOpcionas(){\r\n                const response = await fetch(\"http://localhost:3000/opcionais\")\r\n                const dados = await response.json();\r\n                this.ListaComplementos = dados\r\n                this.ListaBebidas = dados\r\n            }\r\n        },\r\n        mounted() {\r\n            this.getTipoPontos();\r\n            this.getOpcionas();\r\n            \r\n        },\r\n    };\r\n</script>\r\n<style scoped> \r\n#foto-content {\r\n    margin-bottom: 16px ;\r\n    border-radius: 16px;\r\n    position: relative;\r\n    z-index: -1;\r\n    justify-content: center;\r\n    width: 100%;\r\n    height: 180px;\r\n    object-fit: cover;\r\n}\r\n\r\n#nome-hamburguer-content\r\n\r\n)\r\n</style>"],"mappings":"AA4DI,eAAc;EACVA,IAAI,EAAE,iBAAiB;EACvBC,KAAK,EAAE;IACHC,OAAO,EAAE;EACb,CAAC;EACDC,IAAIA,CAAA,EAAG;IACH,OAAO;MACHC,gBAAgB,EAAE,EAAE;MACpBC,YAAY,EAAC,EAAE;MACfC,iBAAiB,EAAC;IACtB,CAAC;EACL,CAAC;EACDC,OAAO,EAAE;IACL,MAAMC,aAAaA,CAAA,EAAG;MAClB,MAAMC,QAAO,GAAI,MAAMC,KAAK,CAAC,oCAAoC;MACjE,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnC,IAAI,CAACR,gBAAe,GAAIO,KAAK;IACjC,CAAC;IACD,MAAME,WAAWA,CAAA,EAAE;MACf,MAAMJ,QAAO,GAAI,MAAMC,KAAK,CAAC,iCAAiC;MAC9D,MAAMC,KAAI,GAAI,MAAMF,QAAQ,CAACG,IAAI,CAAC,CAAC;MACnC,IAAI,CAACN,iBAAgB,GAAIK,KAAI;MAC7B,IAAI,CAACN,YAAW,GAAIM,KAAI;IAC5B;EACJ,CAAC;EACDG,OAAOA,CAAA,EAAG;IACN,IAAI,CAACN,aAAa,CAAC,CAAC;IACpB,IAAI,CAACK,WAAW,CAAC,CAAC;EAEtB;AACJ,CAAC","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}