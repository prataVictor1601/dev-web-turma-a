complemento\r\n                this.ListaBebidas = dados.bebidas\r\n            },\r\n            async criarPedido(e){\r\n                const dadosPedidos = {\r\n                    nome: this.nomeCliente,\r\n                    ponto: this.pontoCarneSelecionado,\r\n                    bebidas: Array.from(this.ListaBebidasSelecionadas),\r\n                    complemento:  Array.from(this.ListaComplementoSelecionados),\r\n                    burguer: this.burguer,\r\n                    statusId: 5\r\n\r\n                }\r\n\r\n\r\n            }\r\n        },\r\n        mounted() {\r\n            this.getTipoPontos();\r\n            this.getOpcionas();\r\n            \r\n        },\r\n    };\r\n</script>\r\n<style scoped> \r\n#foto-content {\r\n    margin-bottom: 16px ;\r\n    border-radius: 16px;\r\n    position: relative;\r\n    z-index: -1;\r\n    justify-content: center;\r\n    width: 100%;\r\n    height: 180px;\r\n    object-fit: cover;\r\n}\r\n\r\n#nome-hamburguer-content{\r\n    font-size:43px;\r\n    font-weight: bold;\r\n    text-align: start;\r\n    margin-bottom: -110px;\r\n    margin-left: 40px;\r\n    color: antiquewhite;\r\n    padding: 16px;\r\n}\r\n#form-pedido{\r\n    max-width: 750px;\r\n    margin: 0 auto;\r\n}\r\n.inputs{\r\n    display: flex;\r\n    flex-direction: column;\r\n    margin-bottom: 16px;\r\n}\r\nlabel{\r\n    font-weight: bold;\r\n    margin-bottom: 16px;\r\n    color: black;\r\n    padding: 5px 12px;\r\n    flex-direction: start;\r\n    display: flex;\r\n    border-left: 4px solid darkgoldenrod;\r\n}\r\n\r\ninput,select{\r\n    padding: 12px;\r\n    width: 300px;\r\n    border: solid black 1px;\r\n    border-radius: 8px;\r\n    height: 20px;\r\n    font-size: 12px;\r\n}\r\n\r\nselect{\r\n    height: 45px;\r\n}\r\n\r\n#opcionais-titulo{\r\n    width: 100%;\r\n}\r\n\r\n#opcionas-subtitulo{\r\n    display: flex;\r\n    align-items: flex-start;\r\n    align-content: center;\r\n    width: 100%;\r\n    margin-bottom: 12px;\r\n}\r\n\